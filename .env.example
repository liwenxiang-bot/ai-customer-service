# ============================================================
#  AI Customer Service — environment configuration (example)
#  Copy to `.env` and fill in real secrets. Never commit `.env`.
# ============================================================

# ---- App ----
APP_ENV=development                 # development | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string
# Public chat/backend origin (where the widget + API are served, e.g. https://chat.example.com).
# IMPORTANT: this is also the base for customer attachment URLs (served via /api/chat/media/…),
# so in production it MUST be your real public chat domain or uploaded images will 404.
APP_BASE_URL=http://localhost:8000
# 业务时区：统计「今日 / 趋势」按此时区切天；存储与 API 仍为 UTC，前端按浏览器本地展示。
APP_TIMEZONE=Asia/Shanghai
# Admin frontend base URL (e.g. https://admin.example.com); used in handoff notification links.
# Empty → falls back to APP_BASE_URL. (Setting only this and leaving APP_BASE_URL as the
# placeholder is the classic mistake that breaks image URLs — set BOTH in production.)
ADMIN_BASE_URL=

# ---- Postgres ----
POSTGRES_USER=acs
POSTGRES_PASSWORD=acs_dev_pass
POSTGRES_DB=acs
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async SQLAlchemy URL (overrides the discrete vars above if set)
# DATABASE_URL=postgresql+asyncpg://acs:acs_dev_pass@localhost:5432/acs

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# ---- Object storage (MinIO / S3) ----
# Where customer-uploaded attachments (images/docs) are stored. MinIO stays PRIVATE
# (bound to 127.0.0.1 in docker-compose); files are served back to browsers/LLM through
# the backend at {APP_BASE_URL}/api/chat/media/… — no public bucket or nginx /media rule needed.
S3_ENDPOINT_URL=http://localhost:9000  # internal endpoint the backend uses to read/write (in Docker: http://minio:9000)
# S3_PUBLIC_URL is NO LONGER USED (media is proxied via APP_BASE_URL). Kept only for compatibility.
S3_PUBLIC_URL=http://localhost:9000
MINIO_ROOT_USER=minioadmin            # production: change to a strong unique value
MINIO_ROOT_PASSWORD=minioadmin        # production: change to a strong unique value
S3_ACCESS_KEY=minioadmin              # usually same as MINIO_ROOT_USER
S3_SECRET_KEY=minioadmin              # usually same as MINIO_ROOT_PASSWORD
MINIO_BUCKET=acs-media
S3_REGION=us-east-1

# ---- Auth / JWT ----
JWT_SECRET=change-me-jwt-secret
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
# Default super-admin bootstrapped on first run (see scripts/bootstrap.py)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# ---- LLM (OpenAI-compatible) ----
# These are DEFAULTS / fallbacks. Live config is stored in DB (ai_configs) and
# editable from the admin UI. Env is used for the first boot + secrets.
LLM_PROVIDER=openai                 # label only; any OpenAI-compatible endpoint
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ---- Embedding ----
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536                  # not hard-wired in schema; used at ingest time
EMBEDDING_BATCH_SIZE=10             # inputs per /embeddings call; 通义 text-embedding-v4 caps at 10 (OpenAI allows more)
EMBEDDING_REBUILD_CONCURRENCY=6     # items embedded in parallel during a full rebuild; lower if you hit QPS limits

# ---- Rerank (optional) ----
RERANK_ENABLED=false
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=bge-reranker-v2-m3

# ---- Retrieval params (defaults; overridable in admin AI config) ----
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_VECTOR_WEIGHT=0.6
RAG_KEYWORD_WEIGHT=0.4
# Vector semantic floor — drop chunks below this cosine similarity before fusion.
# Main guard against "always hit". Calibrate per embedding model
# (OpenAI ~0.2-0.35, BGE/Jina ~0.4-0.5).
RAG_VECTOR_MIN_SIM=0.25
# Final relevance floor on rerank scores (only when RERANK_ENABLED=true; 0 = off).
RAG_MIN_SCORE=0.0
# Trigram floor for keyword / exact-substring matching.
RAG_TRGM_THRESHOLD=0.1
# Candidate pool = TOP_K * this, before fusion/rerank.
RAG_CANDIDATE_MULTIPLIER=8

# ---- Anti-abuse / cost control ----
RATE_LIMIT_USER_PER_MIN=20
RATE_LIMIT_IP_PER_MIN=60
DAILY_COST_CAP_USD=10.0             # circuit breaker; 0 disables
SESSION_IDLE_TIMEOUT_MINUTES=30
MAX_TOOL_CALLS_PER_TURN=6

# ---- Content safety (optional) ----
CONTENT_SAFETY_ENABLED=false

# ---- Semantic cache (optional) ----
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_THRESHOLD=0.95

# ---- Observability (optional Langfuse) ----
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---- Privacy / retention ----
DATA_RETENTION_DAYS=180             # 0 disables auto-cleanup

# ---- CORS / widget ----
# NOTE: the API now sends an open CORS policy (Access-Control-Allow-Origin: *, no credentials)
# because the widget embeds on arbitrary merchant domains. This is safe — admin auth is
# Bearer-token (no cookies) and the chat API is gated per-channel by an allowed-domains
# whitelist (set in 渠道配置 → Web). So ADMIN_CORS_ORIGINS below is currently unused; the real
# embed gate is the per-channel domain whitelist in the DB.
ADMIN_CORS_ORIGINS=http://localhost:5173

# ---- Docker full-stack ports (make stack-up) ----
# Host ports the app containers publish. Change if already in use locally.
BACKEND_PORT=8000
ADMIN_PORT=8080
